{
  "name": "reminder-hub",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm -w apps/web run dev",
    "web:build": "npm -w apps/web run build",
    "web:start": "npm -w apps/web run start",
    "web:check": "npm -w apps/web run check",
    "desktop:dev": "npm -w apps/desktop run tauri:dev",
    "desktop:build": "npm -w apps/desktop run tauri:build",
    "mobile:sync": "npm -w apps/mobile run sync",
    "mobile:android": "npm -w apps/mobile run android",
    "mobile:ios": "npm -w apps/mobile run ios"
  },
  "engines": {
    "node": ">=20"
  }
}
